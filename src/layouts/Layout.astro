---
// Frontmatter section (runs on server)
interface Props {
    title?: string;
}

const { title = 'Python REPL IDE' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <div id="app-loading" style="height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0a0a0a;color:#e5e5e5;font-family:monospace;">
            <div style="width:2.5rem;height:2.5rem;border:3px solid #333;border-top-color:#2563eb;border-radius:50%;animation:spin 1s linear infinite;"></div>
            <p style="margin-top:1rem;color:#999;">Loading Python REPL IDE...</p>
        </div>
        <style>
            @keyframes spin { to { transform: rotate(360deg); } }
        </style>
        <slot />
    </body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>