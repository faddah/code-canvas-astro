{
  "name": "code-canvas-astro",
  "type": "module",
  "version": "2.4.0",
  "scripts": {
    "astro": "astro --host",
    "dev": "astro dev --host",
    "lint": "eslint .",
    "build": "astro build",
    "preview": "astro preview --host",
    "preview:ci": "concurrently --kill-others-on-fail --names \"preview,proxy\" --prefix-colors \"cyan,magenta\" \"astro preview --host --port 4322\" \"node e2e/https-proxy.mjs\"",
    "start": "node ./dist/server/entry.mjs --host",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "release": "standard-version",
    "postrelease": "git push origin main --follow-tags",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "node -e \"if(!process.env.CI){require('child_process').execSync('lsof -ti :4321 | xargs kill -9 2>/dev/null || true')}\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "test:all:watch": "vitest --watch && playwright test --watch"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.3",
    "@clerk/astro": "^3.0.17",
