    "embla-carousel-react": "^8.6.0",
    "eslint": "^10.2.1",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
